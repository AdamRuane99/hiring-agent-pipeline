# LLM Provider — change this to switch providers, no other code changes needed
# Options: ollama | gemini | openai | hf_api | local_hf
LLM_PROVIDER=hf_api

# ─── HuggingFace Inference API (default — free tier) ──────────────────────────
# Get a free token at huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_xxx
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Embeddings — always local, never needs a key
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Uncomment below to switch provider ─────────────────────────────────────────

# Google Gemini (free tier — not available in EU)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza_xxx
# GEMINI_MODEL=gemini/gemini-2.0-flash-lite

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# HuggingFace Inference API (free tier)
# LLM_PROVIDER=hf_api
# HUGGINGFACE_API_TOKEN=hf_xxx
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Local HuggingFace (no API key, slow CPU inference, needs ~2GB disk)
# LLM_PROVIDER=local_hf
# HF_MODEL=Qwen/Qwen2.5-0.5B-Instruct
